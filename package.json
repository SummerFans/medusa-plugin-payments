{
  "name": "medusa-plugin-payments",
  "version": "0.0.1",
  "description": "Stripe and PayPal payment modules and providers for Medusa v2 commerce frameworks.",
  "author": "SummerFans (https://github.com/SummerFans)",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SummerFans/medusa-plugin-payments.git"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-plugin-payment",
    "medusa-v2",
    "stripe",
    "paypal"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "lint": "medusa lint",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "@paypal/paypal-server-sdk": "^2.4.0",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.16.0",
    "@medusajs/cli": "^2.16.0",
    "@medusajs/eslint-plugin": "^2.16.0",
    "@medusajs/framework": "^2.16.0",
    "@medusajs/icons": "^2.16.0",
    "@medusajs/medusa": "^2.16.0",
    "@medusajs/test-utils": "^2.16.0",
    "@medusajs/ui": "4.1.16",
    "@swc/core": "^1.7.28",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.16.0",
    "@medusajs/cli": "^2.16.0",
    "@medusajs/framework": "^2.16.0",
    "@medusajs/icons": "^2.16.0",
    "@medusajs/medusa": "^2.16.0",
    "@medusajs/test-utils": "^2.16.0"
  },
  "engines": {
    "node": ">=20"
  }
}
